{
  "manifest_version": 3,
  "name": "Comet Guide Overlay",
  "version": "1.0",
  "description": "Shows your guide's pointer and messages on any page during a Comet session.",
  "permissions": ["storage"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
